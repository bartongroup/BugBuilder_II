from glob import glob
import os

genome_size = 5_000_000 # 5 Mbp, typical for Bacillus subtilis, and median-ish for Bacillus as a whole

def get_spades_mode(wildcards, input):
    """
    Determine SPAdes mode based on estimated coverage from input FASTQ files.
    """
    # Estimate total bases: Gzipped FASTQ is roughly 1 byte per base 
    # (conservative estimate including quality scores and headers)
    file_size_bytes = os.path.getsize(input.fq1) + os.path.getsize(input.fq2)
    estimated_coverage = file_size_bytes / genome_size
    
    if estimated_coverage > 100:
        return "--isolate"
    else:
        return "--careful"

CONDA_PREFIX=os.environ['CONDA_PREFIX']
BAKTA_DB_PATH="{}/bakta_db/db".format(CONDA_PREFIX)

SAMPLES=glob('data/*')
SAMPLES=[os.path.basename(x) for x in SAMPLES]
LONG_SAMPLES=[]
SHORT_SAMPLES=[]

for sample in SAMPLES:
    if os.path.exists(f"data/{sample}/long_reads"):
        LONG_SAMPLES.append(sample)
    else:
        SHORT_SAMPLES.append(sample)

print("Samples with long reads:", LONG_SAMPLES)
print("Samples with short reads:", SHORT_SAMPLES)


