containers = config['containers']
apptainer_cache = config.get("apptainer_cache")

if apptainer_cache:
    cache_path = os.path.abspath(os.path.expanduser(apptainer_cache))
    os.makedirs(cache_path, exist_ok=True)

    try:
        os.chmod(cache_path, 0o2777)
    except PermissionError:
        print(f"Warning: Could not set permissions on {cache_path}")
    
    os.environ["APPTAINER_CACHEDIR"] = cache_path
    os.environ["SNAKEMAKE_CONTAINER_CACHE"] = cache_path

