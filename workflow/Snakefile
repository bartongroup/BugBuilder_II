rule multiqc:
    input:
        expand('data/{sample}/trimmed_short_reads/{sample}_fastp.json', sample=SAMPLES)
    output:
        'workflow/reports/multiqc_report.html'
    container: "docker://quay.io/biocontainers/multiqc:1.14--pyhdfd78af_0"
    log: 'workflow/logs/multiqc.log'
    shell:
        """
        multiqc data/ \
                --outdir workflow/reports/ \
                --filename multiqc_report.html \
                --force > {log} 2>&1
        """